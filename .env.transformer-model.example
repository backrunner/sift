# Copy this file to .env.transformer-model and keep the real file out of git.
#
# The transformer upload script loads .env.transformer-model automatically when
# present. You can also pass --env-file /path/to/file or set
# SIFT_TRANSFORMER_MODEL_ENV_FILE.

# Public HTTPS root used for immutable releases and the signed v2 channel.
SIFT_TRANSFORMER_MODEL_BASE_URL=https://sift.alkinum.io/models

# Ed25519 private key used only by the publisher. Generate it with:
#   openssl genpkey -algorithm ED25519 -out ~/.config/sift/model-release-ed25519.pem
# Put the matching raw public-key base64 in SiftApp release configuration.
SIFT_MODEL_SIGNING_KEY=/absolute/path/to/model-release-ed25519.pem
SIFT_MODEL_SIGNING_KEY_ID=release-2026

# Cloudflare R2 destination. Releases go under models/releases and the mutable
# channel pointer goes under models/channels/v2.
SIFT_MODEL_R2_BUCKET=sift-public
SIFT_MODEL_R2_PREFIX=models

# Cloudflare R2 S3-compatible endpoint inputs.
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
# SIFT_MODEL_R2_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com

# R2 access key with least-privilege write access to the model bucket.
AWS_ACCESS_KEY_ID=replace-with-r2-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
AWS_REGION=auto

# Optional: use an AWS CLI profile instead of AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY.
# AWS_PROFILE=sift-r2
