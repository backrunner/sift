# Copy this file to .env.testflight and keep the real file out of git.
#
# The TestFlight script loads .env.testflight automatically when present.
# You can also pass --env-file /path/to/file or set SIFT_TESTFLIGHT_ENV_FILE.

# Apple Developer team used for automatic signing.
SIFT_DEVELOPMENT_TEAM=PB8H83VL3Z

# Optional default build number. CLI --build-number overrides this value.
SIFT_BUILD_NUMBER=2

# Optional Xcode archive/export overrides.
SIFT_IOS_SCHEME=SiftApp
SIFT_IOS_CONFIGURATION=Release
# SIFT_ARCHIVE_PATH=build/ios/archives/sift-app-store.xcarchive
# SIFT_EXPORT_PATH=build/ios/testflight-export
# SIFT_EXPORT_OPTIONS_PLIST=apps/ios/ExportOptionsAppStore.plist

# Optional App Store Connect API key for CI or unattended uploads.
# Create this in App Store Connect and keep the .p8 outside the repository.
# SIFT_APPSTORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# SIFT_APPSTORE_CONNECT_API_KEY_ID=XXXXXXXXXX
# SIFT_APPSTORE_CONNECT_API_KEY_ISSUER_ID=00000000-0000-0000-0000-000000000000
